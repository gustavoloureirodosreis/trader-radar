# Copy this file to .env (which is gitignored) and fill in what you have.
# IMPORTANT: only use READ/rate-limit keys here. Never put a wallet private
# key or a trading agent key in this project — nothing here trades.

# Pacifica "API config key" (sent as PF-API-KEY header). OPTIONAL.
# All data used is public; this only raises the rate limit from ~125 to 300+
# credits/min so the Pacifica pass runs ~2.5x faster.
# Get one via the Pacifica app / docs: https://docs.pacifica.fi/api-documentation/api/rate-limits/api-key-rate-limiting
PACIFICA_API_KEY=

# Hyperliquid needs NO key for anything this tool does (leaderboard and
# positions are public). If you were issued an HL API wallet key, do not put
# it here - it is a signing key for trading, not a read key.

# Tuning (defaults shown)
#TOP_N=100
#HL_MIN_EQUITY_USD=50000
#PCF_MIN_EQUITY_USD=10000
#SNAPSHOTS_DIR=./snapshots
